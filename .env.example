# Environment Variables Template
# Copy this file to .env and fill in your actual values

# Set to True to use sqlite3 database instead of MySQL for local development
DEVELOPMENT=True

# Django Settings
SECRET_KEY=change-this-to-a-random-50-character-string-in-production
DEBUG=False
ALLOWED_HOSTS=your-domain.com,www.your-domain.com,api.your-domain.com

# Database Configuration (MySQL)
DB_NAME=medical_api
DB_USER=medical_user
DB_PASSWORD=strong-database-password-here
DB_HOST=127.0.0.1
DB_PORT=3306

# Celery Configuration
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# CORS Configuration (comma-separated)
CORS_ALLOWED_ORIGINS=https://your-frontend.com,https://www.your-frontend.com
CSRF_TRUSTED_ORIGINS=https://your-frontend.com,https://www.your-frontend.com
# Optional: Sentry for error tracking
# SENTRY_DSN=your-sentry-dsn-here

# Security Settings
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
