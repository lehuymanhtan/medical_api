# Environment Variables Template
# Copy this file to .env and fill in your actual values

# Set to True to use sqlite3 database instead of PostgreSQL for local development
# DEVELOPMENT=True

# Django Settings
SECRET_KEY=change-this-to-a-random-50-character-string-in-production
DEBUG=False

# Database Configuration (PostgreSQL)
DB_NAME=medical_api
DB_USER=medical_user
DB_PASSWORD=strong-database-password-here
DB_HOST=127.0.0.1
DB_PORT=5432
# Set to True for cloud databases like Supabase that require SSL connections
# DB_SSLMODE_REQUIRE=True

# Celery Configuration
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Optional: Sentry for error tracking
# SENTRY_DSN=your-sentry-dsn-here

# Optional: Firebase credentials
# You can use either a path to the JSON file or a base64 encoded string of the JSON
# FIREBASE_CREDENTIALS_PATH=firebase-adminsdk.json
# FIREBASE_CREDENTIALS_BASE64=your_base64_encoded_json_here

# Optional: Trusted Proxy IPs
# TRUSTED_PROXY_IPS=192.168.1.1,192.168.1.2

# Optional: Internal IPs for Debug Toolbar
# INTERNAL_IPS=127.0.0.1

# Security Settings
SECURE_SSL_REDIRECT=True

# Resend (transactional email – password reset)
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=your@email.address
# You can even add a display name if you want, like this:
# RESEND_FROM_EMAIL="name <noreply@your-verified-domain.com>"

